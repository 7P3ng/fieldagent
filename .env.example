# FieldAgent reads model API keys from the environment ONLY (public repo — never commit real keys).

# DeepSeek (OpenAI-compatible) — the live eval target (Phase 4). Source your env file before a live run,
# e.g. `source /etc/skill-tuning/skill-tuning.env`, which on this host sets OSSLLM_URL + OSSLLM_MODEL.
OSSLLM_API_KEY=
OSSLLM_MODEL=deepseek-v4-pro
# Endpoint base. This host sets OSSLLM_URL (no /v1 suffix); the public default is https://api.deepseek.com/v1.
OSSLLM_URL=https://api.deepseek.com
# OSSLLM_BASE_URL is an accepted fallback name for the same value.

# Anthropic — OPTIONAL, gates the cross-model table (Phase 7, not built in this run).
ANTHROPIC_API_KEY=

# Eval safety knobs:
#   FIELDAGENT_LIVE=1              # opt in to PAID calls (default off = dry-run, zero cost)
#   FIELDAGENT_MAX_USD=1.00       # refuse a live run whose pre-estimate exceeds this
#   FIELDAGENT_EVAL_CONCURRENCY=4 # bound the eval fan-out (default 4, max 8)
